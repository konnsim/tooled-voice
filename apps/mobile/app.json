{
  "expo": {
    "name": "Tooled Voice",
    "slug": "tooled-voice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": { "NSMicrophoneUsageDescription": "Tooled Voice uses the microphone while you hold the talk button." },
      "bundleIdentifier": "com.tooledvoice.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["RECORD_AUDIO"],
      "package": "com.tooledvoice.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [["expo-secure-store", {"configureAndroidBackup": true}]],
    "scheme": "tooledvoice"
  }
}
