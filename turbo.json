{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "check": { "dependsOn": ["^check"], "outputs": [] },
    "test": { "dependsOn": ["^check"], "outputs": ["coverage/**"] },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:native": {
      "cache": false,
      "persistent": true
    },
    "android": {
      "cache": false,
      "persistent": true
    },
    "ios": {
      "cache": false,
      "persistent": true
    },
    "web": {
      "cache": false,
      "persistent": true
    }
  }
}
